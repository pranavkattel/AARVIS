flowchart TD
    A([Start]) --> B["User asks AARVIS about email"]
    B --> C["LangGraph detects email intent"]
    C --> D{"Requested email action?"}

    D -- Read unread --> E["Call get_emails"]
    E --> F["Fetch unread Gmail messages"]
    F --> G["Return sender, subject, and preview"]

    D -- Summarize sender --> H["Call summarize_email_by_sender"]
    H --> I["Search latest email from sender"]
    I --> J["Return subject and summary"]

    D -- Send email --> K["Call send_email"]
    K --> L{"Recipient is contact name or email?"}
    L -- Contact name --> M["Look up contacts.csv"]
    L -- Direct email --> N["Use provided email"]
    M --> O{"Contact found?"}
    O -- No --> P["Ask user for direct email address"]
    O -- Yes --> Q["Resolve recipient email"]
    N --> R{"Body already provided?"}
    Q --> R
    R -- Yes --> S["Create MIME message directly"]
    R -- No --> T["Auto compose subject and body with local LLM"]
    T --> S
    S --> U["Send message through Gmail API"]
    U --> V["Return confirmation to AARVIS"]

    G --> W([End])
    J --> W
    P --> W
    V --> W
