flowchart TD
    A([Start]) --> B["Dashboard loads or refresh timer fires"]
    B --> C["Browser fetches /api/news"]
    C --> D["Server resolves session user"]
    D --> E{"User has saved interests?"}
    E -- Yes --> F["Build category or query from interests"]
    E -- No --> G["Use default top headlines query"]
    F --> H["Call News API"]
    G --> H
    H --> I{"API returned articles?"}
    I -- Yes --> J["Select top headlines"]
    I -- No --> K["Create fallback news message"]
    J --> L["Return JSON to browser"]
    K --> L
    L --> M["Render headlines in news panel"]
    M --> N([End])
