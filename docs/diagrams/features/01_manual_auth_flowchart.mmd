flowchart TD
    A([Start]) --> B["Open login or register page"]
    B --> C{"Choose action"}

    C -- Register --> D["Enter full name, username, email, and password"]
    D --> E["POST /api/register"]
    E --> F{"Username or email already exists?"}
    F -- Yes --> G["Show validation error"]
    G --> D
    F -- No --> H["Create user in SQLite"]
    H --> I["Issue session token and set cookie"]
    I --> J["Redirect to dashboard"]

    C -- Login --> K["Enter username and password"]
    K --> L["POST /api/login"]
    L --> M{"Credentials valid?"}
    M -- No --> N["Show invalid credentials error"]
    N --> K
    M -- Yes --> O["Issue session token and set cookie"]
    O --> J

    J --> P{"User logs out?"}
    P -- No --> Q([End - active session])
    P -- Yes --> R["POST /api/logout"]
    R --> S["Clear session and redirect to login"]
    S --> T([End])
