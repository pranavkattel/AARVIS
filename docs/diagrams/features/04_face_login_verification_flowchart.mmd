flowchart TD
    A([Start]) --> B["Open login page"]
    B --> C["Start camera automatically"]
    C --> D["Capture frame and POST /api/face/login"]
    D --> E{"Face matched above threshold?"}
    E -- No --> F["Show Looking for your face and retry"]
    F --> D
    E -- Yes --> G["Issue session token and redirect to dashboard"]
    G --> H["Call /api/face/check-cache"]
    H --> I{"Cache still valid?"}
    I -- Yes --> J["Show personalized content"]
    I -- No --> K["Capture frame and POST /api/face/verify"]
    K --> L{"Known face detected?"}
    L -- Yes --> M["Refresh face cache and show personalized content"]
    L -- No --> N["Hide personalized widgets and retry later"]
    M --> O{"Continue session?"}
    N --> O
    O -- Yes --> H
    O -- No --> P([End])
