flowchart TD
    A([Start]) --> B["Dashboard loads or refresh timer fires"]
    B --> C["Browser fetches /api/weather"]
    C --> D["Server resolves session user"]
    D --> E{"User has saved location?"}
    E -- Yes --> F["Use user location"]
    E -- No --> G["Use default location Kathmandu"]
    F --> H["Call Weather API forecast endpoint"]
    G --> H
    H --> I{"API success?"}
    I -- Yes --> J["Format current temp, condition, min, and max"]
    I -- No --> K["Create fallback weather response"]
    J --> L["Return JSON to browser"]
    K --> L
    L --> M["Update weather widget on mirror UI"]
    M --> N([End])
